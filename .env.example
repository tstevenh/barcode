# Copy to .env.local for local development (git-ignored). All values are optional
# for the core site; the waitlist endpoint needs the Supabase pair to store signups.

# Port for the local server (npm start). Default: 3000
PORT=3000

# Public API rate limit: requests per IP per minute. Default: 120
RATE_LIMIT_RPM=120

# --- Pro / API waitlist (/api/waitlist) -------------------------------------
# Supabase — REQUIRED to store signups. Service-role key is server-side ONLY.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Table name. Default: waitlist
WAITLIST_TABLE=waitlist

# Resend — OPTIONAL. Enables the confirmation email. Without these, signups are
# still stored, no email is sent.
RESEND_API_KEY=
WAITLIST_FROM_EMAIL=Barcode APIs <hello@barcodeapis.com>

# Optional: CC every signup to your own inbox.
WAITLIST_NOTIFY_EMAIL=
